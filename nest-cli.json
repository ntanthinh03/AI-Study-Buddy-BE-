{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "builder": "swc"
  },
  "watchOptions": {
    "watchAssets": false,
    "exclude": [
      "scratch/**/*",
      "uploads/**/*",
      "test/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "**/*.md"
    ]
  }
}

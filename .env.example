# ==========================
# Server
# ==========================
PORT=3001

# ==========================
# Main PostgreSQL (TypeORM)
# ==========================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=1
DB_DATABASE=postgres

# ==========================
# Vector PostgreSQL (PGVector for RAG)
# Keep same as DB_* if you use one database.
# ==========================
DATABASE_URL=postgresql://postgres:1@localhost:5432/postgres

# ==========================
# Local AI (Ollama)
# ==========================
# Preferred quantization for the whole project: Q4_K_M
# Use Q4_K_M builds for both text and vision models when pulling local Ollama models.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:14b-instruct
OLLAMA_VISION_MODEL=llama3.2-vision:11b

# ==========================
# Optional legacy variable
# Not used anymore in local-only mode.
# ==========================
# GEMINI_API_KEY=

# ==========================
# Auth Forgot Password OTP (Email)
# ==========================
RESET_OTP_EXPIRES_IN_MINUTES=10
RESET_OTP_MAX_ATTEMPTS=5
RESET_PASSWORD_TOKEN_EXPIRES_IN=15m

# ==========================
# Brevo Mailer (for OTP email)
# ==========================
BREVO_API_KEY=
BREVO_FROM_EMAIL=ntanthinh03@gmail.com
BREVO_FROM_NAME=AI Study Buddy Support
# Backward-compatible aliases still supported by the service:
# BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=
MAILER_DEV_FALLBACK=false
